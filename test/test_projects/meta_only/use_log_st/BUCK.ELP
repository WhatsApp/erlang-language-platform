oncall("vscode_erlang")

erlang_application(
    name = "wa_logs",
    srcs = glob(["wa_logs/src/*.erl"]),
    app_src = "wa_logs/src/wa_logs.app.src",
    applications = [
    ],
    includes = glob(["wa_logs/include/*.hrl"]),
    labels = ["user_application"],
    version = "1.0.0",
)

erlang_application(
    name = "app_a",
    srcs = glob(["app_a/src/*.erl"]),
    app_src = "app_a/src/app_a.app.src",
    applications = [
        ":wa_logs",
    ],
    labels = ["user_application"],
    version = "1.0.0",
)
